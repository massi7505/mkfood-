# Dolibarr
# URL racine de l'API REST Dolibarr v17+.
DOLIBARR_API_URL=https://azure-seahorse-800739.hostingersite.com/api/index.php
# Optionnel: cle API fallback serveur/admin. Les appels clients utilisent d'abord User.dolibarrApiKey.
DOLIBARR_API_KEY=

# NextAuth
# Secret aleatoire de 32 caracteres minimum.
NEXTAUTH_SECRET=secret_32_chars_minimum
NEXTAUTH_URL=http://localhost:3000

# Base de donnees (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/portail_b2b

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Portail Client"
NEXT_PUBLIC_ACCOUNTING_EMAIL=compta@votre-entreprise.com
