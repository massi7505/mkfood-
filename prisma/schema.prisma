generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  ADMIN
}

enum OrderStatus {
  DRAFT
  VALIDATED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  VALIDATED
  PAID
  ABANDONED
  OVERDUE
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  companyName  String?
  siret        String?
  address      String?
  phone        String?
  mobile       String?
  billingAddress String?
  shippingAddress String?
  billingEmail String?
  vatNumber    String?
  thirdpartyId Int          @default(0)
  dolibarrApiKey String?
  role         UserRole     @default(CLIENT)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sessions     Session[]
  orders       OrderCache[]

  @@index([email])
  @@index([thirdpartyId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProductCache {
  dolibarrId    String   @id
  ref           String
  label         String
  description   String?
  price         Decimal  @db.Decimal(12, 2)
  priceHt       Decimal  @db.Decimal(12, 2)
  tva           Decimal  @db.Decimal(5, 2)
  unit          String?
  stock         Int      @default(0)
  imageUrl      String?
  categoryId    String?
  categoryLabel String?
  isActive      Boolean  @default(true)
  cachedAt      DateTime @default(now())

  @@index([ref])
  @@index([categoryId])
  @@index([isActive])
}

model OrderCache {
  dolibarrId String      @id
  userId     String
  status     OrderStatus
  total      Decimal     @db.Decimal(12, 2)
  lines      Json
  dateOrder  DateTime
  cachedAt   DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dateOrder])
  @@index([status])
}

model OrderWorkflow {
  id                String   @id @default(cuid())
  dolibarrOrderId   String   @unique
  preparationStatus String   @default("to_prepare")
  driver            String?
  deliveryDate      DateTime?
  deliveryNote      String?
  customerMessage   String?
  customerNotifiedAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([preparationStatus])
}
